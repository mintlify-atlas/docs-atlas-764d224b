  "keyFeatures": [
    "Employee Management with profiles, documents, and disciplinary actions",
    "Recruitment pipeline with job postings, interviews, and candidate tracking",
    "Attendance tracking with biometric device integration and geofencing",
    "Leave management with approval workflows and leave type configuration",
    "Payroll processing with deductions, allowances, and tax calculations",
    "Performance Management System (PMS) with goal tracking and appraisals",
    "Onboarding and offboarding workflows",
    "Helpdesk and ticketing system",
    "Asset management",
    "REST API with JWT authentication and Swagger/ReDoc documentation",
    "Docker support for easy deployment",
    "LDAP authentication and Microsoft Azure AD integration"
  ],
  "publicApiSurface": [
    "GET /api/list/employees/ — List all employees",
    "GET/PUT/DELETE /api/employees/<id>/ — Employee detail",
    "GET/POST /api/employee-work-information/ — Work information",
    "POST /api/clock-in/ — Clock in attendance",
    "POST /api/clock-out/ — Clock out attendance",
    "GET/POST /api/attendance/ — Attendance records",
    "POST /api/attendance-validate/<id> — Validate attendance",
    "GET/POST /api/attendance-request/ — Attendance requests",
    "GET/POST /api/leave-request/ — Leave requests",
    "GET/POST /api/payslip/ — Payslip management",
    "GET/POST /api/asset/ — Asset management",
    "GET/POST /api/helpdesk/ — Helpdesk tickets",
    "POST /api/token/ — Obtain JWT token",
    "POST /api/token/refresh/ — Refresh JWT token"
  ]
}
